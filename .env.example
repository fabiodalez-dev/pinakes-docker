# Copy to .env and adjust. All values are optional for a quick local trial,
# but production deployments should set strong DB passwords, a stable
# PLUGIN_ENCRYPTION_KEY, and ADMIN_* for a fully headless install.

# ---- Image / version ----
# Tag to pull (latest | <version>, e.g. 0.7.22). Ignored when building locally.
PINAKES_TAG=latest
# Pinakes release packaged when building locally (docker compose up --build).
PINAKES_VERSION=0.7.22

# ---- HTTP ----
HTTP_PORT=8080

# ---- Database ----
DB_NAME=pinakes
DB_USER=pinakes
DB_PASS=change-me-pinakes
DB_ROOT_PASS=change-me-root

# ---- Application ----
APP_ENV=production
APP_LOCALE=it_IT          # it_IT | en_US | de_DE | fr_FR
APP_CANONICAL_URL=        # e.g. https://library.example.com (needed for correct email links behind a proxy)
APP_DEBUG=false
DISPLAY_ERRORS=false
FORCE_HTTPS=false
SESSION_LIFETIME=3600

# ---- Scheduler (automatic notification emails + nightly maintenance) ----
# The container runs supercronic so due-soon/overdue loan emails and nightly
# maintenance fire on their own. Set TZ to your library's local time so the
# "opening hours" schedule (hourly 08:00–20:00) matches reality (default UTC).
TZ=UTC
# Set to 1 only if you run cron/automatic-notifications.php + full-maintenance.php
# from an external scheduler and want the in-container one off.
PINAKES_CRON_DISABLED=0

# Stable key so encrypted plugin settings survive container recreation.
# Generate with:  printf 'base64:%s\n' "$(openssl rand -base64 32)"
PLUGIN_ENCRYPTION_KEY=

# ---- Headless install (set BOTH to skip the web wizard entirely) ----
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Admin
ADMIN_SURNAME=User
